{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Enterprise AI Agent Platform",
  "uid": "enterprise-ai-agent",
  "tags": ["ai-agent", "openshift", "langraph"],
  "timezone": "Asia/Tokyo",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "LLM リクエスト数/分",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(ai_agent_llm_requests_total[5m])) * 60",
          "legendFormat": "requests/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "LLM P95 レイテンシ",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, sum(rate(ai_agent_llm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Tool 成功率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(ai_agent_tool_executions_total{success=\"true\"}[5m])) / sum(rate(ai_agent_tool_executions_total[5m]))",
          "legendFormat": "成功率"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "承認待ち操作",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "ai_agent_pending_approvals",
          "legendFormat": "承認待ち"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Tool 実行数 (ツール別)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(ai_agent_tool_executions_total[5m])) by (tool_name)",
          "legendFormat": "{{ tool_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "LLM トークン使用量 (1時間累計)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(increase(ai_agent_llm_tokens_total[1h])) by (model, token_type)",
          "legendFormat": "{{ model }} / {{ token_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "Business API — HTTP ステータス分布",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"business-api\"}[5m])) by (status)",
          "legendFormat": "HTTP {{ status }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Business API — P99 レイテンシ (エンドポイント別)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"business-api\"}[5m])) by (uri, le))",
          "legendFormat": "{{ uri }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ]
}
