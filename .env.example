# OpenMetadata
OPENMETADATA_HOST=http://localhost:8585
OPENMETADATA_JWT_TOKEN=<generate_from_openmetadata_ui>

# vLLM / LLM (ローカル開発時は Ollama で代替可)
VLLM_BASE_URL=http://localhost:11434/v1
VLLM_MODEL=ibm-granite-20b-code-instruct
VLLM_API_KEY=not-needed

# Quarkus Business API
BUSINESS_API_URL=http://localhost:8080
BUSINESS_API_TOKEN=

# LangGraph チェックポイント (PostgreSQL)
AGENT_DB_URL=postgresql://postgres:postgres@localhost:5432/agentdb

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Quarkus (backend/.env または application.properties で使用)
DB_HOST=localhost
DB_NAME=dronedb
DB_USERNAME=postgres
DB_PASSWORD=postgres
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=drone-platform
KEYCLOAK_CLIENT_ID=business-api
KEYCLOAK_CLIENT_SECRET=secret
